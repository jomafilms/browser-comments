{
  "name": "browser-comments",
  "version": "1.0.0",
  "main": "index.js",
  "bin": {
    "browser-comments": "./cli/dist/bin.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "init-db": "npx tsx scripts/init-db.ts",
    "tickets": "npx tsx cli/bin.ts",
    "cli:build": "tsc -p cli/tsconfig.json",
    "mcp:build": "cd mcp && npm run build",
    "build:widget": "esbuild widget-src/index.js --bundle --format=iife --target=es2020 --banner:js=\"/* Feedback widget — GENERATED from widget-src/. Edit there, then run: npm run build:widget */ 'use strict';\" --outfile=public/widget.js"
  },
  "keywords": [
    "feedback",
    "annotation",
    "visual-feedback",
    "bug-reporting",
    "widget",
    "self-hosted",
    "nextjs"
  ],
  "author": "joma (jomafilms)",
  "license": "MIT",
  "description": "dev·tix — open-source visual feedback widget. Clients annotate any web page and you get a screenshot ticket that pipes straight into your coding agents. Self-hosted on Vercel + Neon. Repo: browser-comments.",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "better-auth": "^1.6.23",
    "dom-to-image-more": "^3.7.1",
    "html2canvas": "^1.4.1",
    "next": "^15.5.12",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
