# Database connection string
# For local PostgreSQL:
DATABASE_URL=postgresql://localhost:5432/browser_comments
# For Neon (production), use your Neon connection string:
# DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require

# Better Auth — owner login for the admin panel at /admin
# Secret used to sign sessions/cookies. Must be >= 32 chars.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Public base URL of this app (used for auth callbacks/cookies).
# Local dev: http://localhost:3000 — in production set your real https origin.
BETTER_AUTH_URL=http://localhost:3000

# Admin secret — DEPRECATED break-glass / back-compat path.
# The admin panel now lives at /admin behind a Better Auth owner login (above).
# ADMIN_SECRET is still accepted as an Authorization: Bearer token (and legacy
# ?admin=) so existing installs and scripts keep working. Leave unset to require
# a real owner login only.
ADMIN_SECRET=change-me-to-a-secure-random-string

# --- Email notifications (all optional) ---
# With NONE of these set, email notifications are simply disabled (one startup
# warning) and everything else works. Notifications are also opt-in per client.
#
# Option A — Resend (recommended, no dependency, uses the REST API):
#   Requires a verified sending domain in your Resend account.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# Option B — SMTP fallback (uses nodemailer). Port 465 = implicit TLS, else STARTTLS.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-smtp-password
#
# The From address for all notification email (required to actually send).
# Must be a verified sender for your provider/domain.
# EMAIL_FROM="Feedback <notifications@yourdomain.com>"
#
# Canonical origin used for links inside emails (falls back to BETTER_AUTH_URL /
# WEBHOOK_BASE_URL / the request origin).
# EMAIL_BASE_URL=https://your-app.example.com
#
# Safety gate: when set (comma-separated), ONLY these addresses receive mail —
# everything else is dropped. Use in staging/testing to avoid emailing real people.
# EMAIL_ALLOWLIST=you@yourdomain.com
#
# Cap on instant per-ticket emails per client per hour (default 20). Above the
# cap, one "paused" notice is sent and the rest fold into the dashboard/digest.
# EMAIL_INSTANT_CAP_PER_HOUR=20
#
# Daily-digest send hour + timezone (default 9am America/Los_Angeles).
# EMAIL_DIGEST_HOUR=9
# EMAIL_DIGEST_TZ=America/Los_Angeles

# Secret guarding the hourly digest cron (/api/cron/digest). Vercel Cron sends
# it as `Authorization: Bearer <CRON_SECRET>`. Without it set, the route is closed.
# CRON_SECRET=change-me-to-a-long-random-string
