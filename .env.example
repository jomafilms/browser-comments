# Database connection string
# For local PostgreSQL:
DATABASE_URL=postgresql://localhost:5432/browser_comments
# For Neon (production), use your Neon connection string:
# DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require

# Better Auth — owner login for the admin panel at /admin
# Secret used to sign sessions/cookies. Must be >= 32 chars.
# Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
# Public base URL of this app (used for auth callbacks/cookies).
# Local dev: http://localhost:3000 — in production set your real https origin.
BETTER_AUTH_URL=http://localhost:3000

# Admin secret — DEPRECATED break-glass / back-compat path.
# The admin panel now lives at /admin behind a Better Auth owner login (above).
# ADMIN_SECRET is still accepted as an Authorization: Bearer token (and legacy
# ?admin=) so existing installs and scripts keep working. Leave unset to require
# a real owner login only.
ADMIN_SECRET=change-me-to-a-secure-random-string
